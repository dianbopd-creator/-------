# ─── Required ──────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-here

# CORS — set to your Vercel frontend URL (no trailing slash)
ALLOWED_ORIGIN=https://your-app.vercel.app

# ─── Optional ──────────────────────────────────────────────────────────────────
# SQLite database path — defaults to /data/database.sqlite in production
# DB_PATH=/data/database.sqlite

# Default admin password (only used when seeding for the first time)
# INITIAL_ADMIN_PASSWORD=your-secure-password-here

# Google AI API Key (for AI report generation)
# GEMINI_API_KEY=your-gemini-key-here

# Port — overridden by Fly.io automatically
# PORT=3001
